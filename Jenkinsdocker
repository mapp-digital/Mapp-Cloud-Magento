FROM node:22-bookworm

ARG GID
ARG UID
ARG UNAME

ENV GROUP_ID=$GID
ENV USER_ID=$UID
ENV USERNAME=$UNAME

ENV SONAR_SCANNER_VERSION=6.2.1.4610
ENV SONAR_SCANNER_HOME=/opt/sonar-scanner
ENV PATH="${SONAR_SCANNER_HOME}/bin:${PATH}"

RUN apt-get update && \
    apt-get install -y zip default-jre-headless unzip && \
    rm -rf /var/lib/apt/lists/*

RUN curl -fsSL "https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-${SONAR_SCANNER_VERSION}-linux-x64.zip" \
      -o /tmp/sonar-scanner.zip && \
    unzip -q /tmp/sonar-scanner.zip -d /opt && \
    mv /opt/sonar-scanner-${SONAR_SCANNER_VERSION}-linux-x64 ${SONAR_SCANNER_HOME} && \
    rm /tmp/sonar-scanner.zip && \
    chmod +x ${SONAR_SCANNER_HOME}/bin/sonar-scanner

RUN mkdir /home/$USERNAME && \
    groupadd -g $GROUP_ID $USERNAME && \
    useradd -r -u $USER_ID -g $USERNAME -d /home/$USERNAME $USERNAME && \
    chown $USERNAME:$USERNAME /home/$USERNAME && \
    truncate -s 0 /var/log/lastlog /var/log/faillog;

USER $USERNAME
WORKDIR /home/$USERNAME

# Increase the V8 heap size to prevent mono-repo commands running out of memory when run in parallel
ENV NODE_OPTIONS=--max_old_space_size=8192

ENV CI=true
